#!/bin/bash
# Whisper Local Server Control Script
# Usage: ./serverctl [start|stop|restart|status]

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_DIR"

# Files
PID_FILE="/tmp/whisper_webui.pid"
OLLAMA_FLAG="/tmp/whisper_ollama_started.txt"
LOG_FILE="/tmp/whisper_webui.log"

# Check if Ollama is installed as a system service
is_ollama_system_service() {
    if brew services list 2>/dev/null | grep -q "^ollama"; then
        return 0
    fi
    return 1
}

# Check if Ollama is running
is_ollama_running() {
    pgrep -f "ollama serve" > /dev/null 2>&1
}

start_ollama() {
    if is_ollama_running; then
        echo -e "${BLUE}Ollama (LLM Models) already running${NC}"
        return
    fi
    
    echo -e "${YELLOW}Starting associated models (Ollama LLM)...${NC}"
    if is_ollama_system_service; then
        brew services start ollama
        sleep 2
    else
        ollama serve > /dev/null 2>&1 &
        echo "started" > "$OLLAMA_FLAG"
        sleep 2
    fi
    
    if is_ollama_running; then
        echo -e "${GREEN}Ollama (LLM Models) started${NC}"
    else
        echo -e "${RED}Failed to start Ollama models${NC}"
        exit 1
    fi
}

stop_ollama() {
    echo -e "${YELLOW}Stopping associated models (Ollama LLM)...${NC}"
    if is_ollama_system_service; then
        brew services stop ollama
        sleep 2
    fi
    
    if is_ollama_running; then
        pkill -f "ollama serve" 2>/dev/null || true
    fi
    rm -f "$OLLAMA_FLAG"
    echo -e "${GREEN}Ollama (LLM Models) stopped${NC}"
}

start_webui() {
    # Check if already running
    if [ -f "$PID_FILE" ]; then
        OLD_PID=$(cat "$PID_FILE")
        if kill -0 "$OLD_PID" 2>/dev/null; then
            echo -e "${RED}Web UI already running (PID: $OLD_PID)${NC}"
            return
        fi
        rm -f "$PID_FILE"
    fi
    
    echo -e "${YELLOW}Starting Whisper Local Web UI...${NC}"
    
    # Start server
    source "$PROJECT_DIR/.venv/bin/activate"
    nohup python "$PROJECT_DIR/src/webui.py" > "$LOG_FILE" 2>&1 &
    WEBUI_PID=$!
    
    echo $WEBUI_PID > "$PID_FILE"
    sleep 2
    
    if kill -0 "$WEBUI_PID" 2>/dev/null; then
        echo -e "${GREEN}Whisper Local started!${NC}"
        echo ""
        echo -e "${BLUE}Open in browser:${NC}"
        echo -e "  http://localhost:8080"
        
        # Try to get local IP
        local_ip=$(curl -s http://localhost:8080/ip 2>/dev/null | grep -o '"ip":"[^"]*' | cut -d'"' -f4)
        if [ -n "$local_ip" ] && [ "$local_ip" != "127.0.0.1" ]; then
            echo -e "  http://$local_ip:8080"
        fi
    else
        echo -e "${RED}Failed to start Web UI${NC}"
        [ -f "$LOG_FILE" ] && cat "$LOG_FILE"
        rm -f "$PID_FILE"
        exit 1
    fi
}

stop_webui() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo -e "${YELLOW}Stopping Web UI...${NC}"
            kill "$PID" 2>/dev/null || true
            sleep 1
            kill -9 "$PID" 2>/dev/null || true
            echo -e "${GREEN}Web UI stopped${NC}"
        fi
        rm -f "$PID_FILE"
    else
        # Find by process name
        PID=$(pgrep -f "python.*webui.py" | head -1)
        if [ -n "$PID" ]; then
            echo -e "${YELLOW}Stopping Web UI...${NC}"
            kill "$PID" 2>/dev/null || true
            sleep 1
            kill -9 "$PID" 2>/dev/null || true
            echo -e "${GREEN}Web UI stopped${NC}"
        fi
    fi
}

show_status() {
    echo ""
    echo -e "${BLUE}=== Whisper Local Status ===${NC}"
    echo ""
    
    # Check Web UI
    RUNNING_WEBUI=false
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo -e "${GREEN}Web UI: Running${NC} (PID: $PID)"
            RUNNING_WEBUI=true
        else
            echo -e "${RED}Web UI: Not running${NC} (stale PID file)"
        fi
    else
        PID=$(pgrep -f "python.*webui.py" | head -1)
        if [ -n "$PID" ]; then
            echo -e "${GREEN}Web UI: Running${NC} (PID: $PID)"
            RUNNING_WEBUI=true
        else
            echo -e "${RED}Web UI: Not running${NC}"
        fi
    fi
    
    # Check Ollama
    echo ""
    if is_ollama_running; then
        if is_ollama_system_service; then
            echo -e "${GREEN}Ollama (LLM Models): Running${NC} (system service)"
        else
            echo -e "${GREEN}Ollama (LLM Models): Running${NC} (process)"
        fi
    else
        echo -e "${RED}Ollama (LLM Models): Not running${NC}"
    fi
    
    # Show URLs if running
    if [ "$RUNNING_WEBUI" = true ]; then
        echo ""
        echo -e "${BLUE} URLs:${NC}"
        echo -e "  http://localhost:8080"
        local_ip=$(curl -s http://localhost:8080/ip 2>/dev/null | grep -o '"ip":"[^"]*' | cut -d'"' -f4)
        if [ -n "$local_ip" ] && [ "$local_ip" != "127.0.0.1" ]; then
            echo -e "  http://$local_ip:8080"
        fi
    fi
    
    echo ""
}

case "${1:-}" in
    start)
        start_ollama
        start_webui
        ;;
    stop)
        stop_webui
        stop_ollama
        ;;
    restart)
        stop_webui
        stop_ollama
        sleep 1
        start_ollama
        start_webui
        ;;
    status)
        show_status
        ;;
    *)
        echo ""
        echo "Whisper Local Control"
        echo ""
        echo "Usage: $0 <command>"
        echo ""
        echo "Commands:"
        echo "  start   - Start Ollama + Web UI"
        echo "  stop    - Stop Web UI + Ollama"
        echo "  restart - Restart everything"
        echo "  status  - Show status"
        echo ""
        echo "Examples:"
        echo "  $0 start"
        echo "  $0 stop"
        echo "  $0 status"
        echo ""
        ;;
esac